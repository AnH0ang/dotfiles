{
    //           _   _   _                    _
    //  ___  ___| |_| |_(_)_ __   __ _ ___   (_)___  ___  _ __
    // / __|/ _ \ __| __| | '_ \ / _` / __|  | / __|/ _ \| '_ \
    // \__ \  __/ |_| |_| | | | | (_| \__ \_ | \__ \ (_) | | | |
    // |___/\___|\__|\__|_|_| |_|\__, |___(_)/ |___/\___/|_| |_|
    //                           |___/     |__/
    "[fish]": {
        "editor.defaultFormatter": "bmalehorn.vscode-fish"
    },
    "[html]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[just]": {
        "editor.defaultFormatter": "nefrob.vscode-just-syntax"
    },
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[typst]": {
        "editor.defaultFormatter": "myriad-dreamin.tinymist",
        "editor.formatOnSave": true,
        "editor.wordSeparators": "`~!@#$%^&*()=+[{]}\\|;:'\",.<>/?"
    },
    "[yaml]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "accessibility.underlineLinks": true,
    "chat.agent.maxRequests": 1000,
    "chat.tools.global.autoApprove": true,
    "chat.tools.terminal.autoReplyToPrompts": true,
    "chat.viewSessions.orientation": "stacked",
    "debug.allowBreakpointsEverywhere": true,
    "debug.breakpointsView.presentation": "tree",
    "debug.console.closeOnEnd": true,
    "debug.enableStatusBarColor": true,
    "debug.inlineValues": "auto",
    "debug.onTaskErrors": "showErrors",
    "debug.toolBarLocation": "docked",
    "debugpy.debugJustMyCode": false,
    "debugpy.showPythonInlineValues": true,
    "diffEditor.diffAlgorithm": "advanced",
    "diffEditor.experimental.showMoves": true,
    "diffEditor.ignoreTrimWhitespace": false,
    "diffEditor.useInlineViewWhenSpaceIsLimited": false,
    "diffEditor.wordWrap": "off",
    "editor.accessibilitySupport": "off",
    "editor.codeActionsOnSave": {
        "source.addMissingImports": "explicit",
        "source.fixAll": "explicit",
        "source.organizeImports": "explicit"
    },
    "editor.codeActionWidget.includeNearbyQuickFixes": true,
    "editor.cursorBlinking": "solid",
    "editor.folding": false,
    "editor.fontFamily": "'SF Mono', 'Cascadia Code', 'FiraCode Nerd Font', Menlo, Monaco, 'Courier New', monospace",
    "editor.fontLigatures": true,
    "editor.fontSize": 11,
    "editor.formatOnSave": true,
    "editor.guides.indentation": false,
    "editor.inlayHints.enabled": "off",
    "editor.inlineSuggest.edits.showCollapsed": true,
    "editor.inlineSuggest.enabled": true,
    "editor.inlineSuggest.showToolbar": "always",
    "editor.lineNumbers": "on",
    "editor.linkedEditing": true,
    "editor.minimap.enabled": false,
    "editor.multiCursorModifier": "alt",
    "editor.occurrencesHighlightDelay": 0,
    "editor.quickSuggestionsDelay": 5,
    "editor.renderLineHighlight": "all",
    "editor.scrollbar.horizontal": "hidden",
    "editor.scrollbar.vertical": "hidden",
    "editor.stickyScroll.enabled": true,
    "editor.suggest.preview": true,
    "editor.tabCompletion": "on",
    "editor.wordWrapColumn": 88,
    "errorLens.excludeBySource": [
        "cSpell",
        "YAML(0)"
    ],
    "evenBetterToml.formatter.columnWidth": 100,
    "explorer.autoReveal": "focusNoScroll",
    "explorer.compactFolders": true,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmPasteNative": false,
    "explorer.confirmUndo": "light",
    "explorer.incrementalNaming": "smart",
    "explorer.openEditors.sortOrder": "fullPath",
    "extensions.ignoreRecommendations": true,
    "files.exclude": {
        "**/__pycache__": true,
        "**/.mypy_cache": true,
        "**/.pytest_cache": true,
        "**/.ruff_cache": true,
        "**/*.egg-info": true
    },
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "files.trimTrailingWhitespace": true,
    "git.autofetch": true,
    "git.autoRepositoryDetection": "openEditors",
    "git.blame.editorDecoration.enabled": true,
    "git.confirmSync": false,
    "git.inputValidation": true,
    "git.mergeEditor": true,
    "github.copilot.enable": {
        "*": true,
        "markdown": true,
        "plaintext": false,
        "scminput": false
    },
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "gitlens.codeLens.enabled": false,
    "inlineChat.enableV2": true,
    "inlineChat.notebookAgent": true,
    "json.schemaDownload.trustedDomains": {
        "https://developer.microsoft.com/json-schemas/": true,
        "https://json-schema.org/": true,
        "https://json.schemastore.org/": true,
        "https://raw.githubusercontent.com/devcontainers/spec/": true,
        "https://raw.githubusercontent.com/microsoft/vscode/": true,
        "https://schemastore.azurewebsites.net/": true,
        "https://ui.shadcn.com": true,
        "https://www.schemastore.org/": true
    },
    "jupyter.askForKernelRestart": false,
    "jupyter.debugJustMyCode": false,
    "notebook.codeActionsOnSave": {
        "notebook.source.fixAll": "explicit"
    },
    "notebook.consolidatedRunButton": true,
    "notebook.dragAndDropEnabled": false,
    "notebook.formatOnSave.enabled": true,
    "notebook.globalToolbarShowLabel": "never",
    "notebook.insertToolbarLocation": "hidden",
    "notebook.output.minimalErrorRendering": true,
    "notebook.output.scrolling": true,
    "notebook.output.textLineLimit": 20,
    "notebook.showCellStatusBar": "visible",
    // "python.analysis.autoFormatStrings": true,
    // "python.analysis.autoImportCompletions": true,
    // "python.analysis.diagnosticMode": "workspace",
    // "python.analysis.enablePytestSupport": true,
    // "python.analysis.includeAliasesFromUserFiles": true,
    // "python.analysis.inlayHints.functionReturnTypes": true,
    // "python.analysis.inlayHints.pytestParameters": true,
    // "python.analysis.languageServerMode": "full",
    // "python.analysis.supportDocstringTemplate": true,
    // "python.analysis.typeCheckingMode": "standard",
    "search.smartCase": true,
    "security.promptForRemoteFileProtocolHandling": false,
    "security.workspace.trust.untrustedFiles": "open",
    "terminal.external.osxExec": "Ghostty.app",
    "terminal.integrated.defaultProfile.osx": "fish",
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "terminal.integrated.persistentSessionScrollback": 10000,
    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.shellIntegration.enabled": false,
    "testing.alwaysRevealTestOnStateChange": true,
    "testing.automaticallyOpenPeekView": "failureAnywhere",
    "testing.automaticallyOpenTestResults": "openOnTestFailure",
    "testing.defaultGutterClickAction": "debug",
    "testing.followRunningTest": false,
    "testing.showCoverageInExplorer": false,
    "typos.config": "~/.config/typos/typos.toml",
    "vim.camelCaseMotion.enable": true,
    "vim.easymotion": true,
    "vim.highlightedyank.duration": 300,
    "vim.highlightedyank.enable": true,
    "vim.hlsearch": true,
    "vim.incsearch": true,
    "vim.leader": ";",
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "after": [
                "<C-u>",
                "z",
                "z"
            ],
            "before": [
                "<C-u>"
            ]
        },
        {
            "after": [
                "<C-d>",
                "z",
                "z"
            ],
            "before": [
                "<C-d>"
            ]
        },
        {
            "after": [
                "@",
                "q"
            ],
            "before": [
                "Q"
            ]
        },
        {
            "before": [
                "[",
                "b"
            ],
            "commands": [
                "editor.debug.action.goToPreviousBreakpoint"
            ]
        },
        {
            "before": [
                "]",
                "b"
            ],
            "commands": [
                "editor.debug.action.goToNextBreakpoint"
            ]
        },
        {
            "before": [
                "]",
                "p"
            ],
            "commands": [
                "editor.action.marker.nextInFiles"
            ]
        },
        {
            "before": [
                "[",
                "p"
            ],
            "commands": [
                "editor.action.marker.prevInFiles"
            ]
        },
        {
            "before": [
                "]",
                "c"
            ],
            "commands": [
                "workbench.action.editor.nextChange",
                "workbench.action.compareEditor.nextChange"
            ]
        },
        {
            "before": [
                "[",
                "c"
            ],
            "commands": [
                "workbench.action.editor.previousChange",
                "workbench.action.compareEditor.previousChange"
            ]
        },
        {
            "before": [
                "z",
                "g"
            ],
            "commands": [
                "cSpell.addWordToDictionary"
            ]
        },
        {
            "after": [
                "y",
                "$"
            ],
            "before": [
                "Y"
            ]
        },
        {
            "after": [
                "N",
                "z",
                "z"
            ],
            "before": [
                "N"
            ]
        },
        {
            "after": [
                "n",
                "z",
                "z"
            ],
            "before": [
                "n"
            ]
        },
        {
            "before": [
                "z",
                "="
            ],
            "commands": [
                "cSpell.goToNextSpellingIssueAndSuggest"
            ]
        },
        {
            "before": [
                "g",
                "t"
            ],
            "commands": [
                "editor.action.goToTypeDefinition"
            ]
        },
        {
            "before": [
                "g",
                "r"
            ],
            "commands": [
                "editor.action.goToReferences"
            ]
        },
        {
            "before": [
                "g",
                "i"
            ],
            "commands": [
                "editor.action.goToImplementation"
            ]
        },
        {
            "before": [
                "g",
                "l"
            ],
            "commands": [
                "references-view.showCallHierarchy"
            ]
        },
        {
            "before": [
                "<space>"
            ],
            "commands": [
                "vspacecode.space"
            ]
        },
        {
            "before": [
                ","
            ],
            "commands": [
                "vspacecode.space",
                {
                    "args": "m",
                    "command": "whichkey.triggerKey"
                }
            ]
        }
    ],
    "vim.targets.enable": true,
    "vim.useSystemClipboard": true,
    "vim.visualModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<space>"
            ],
            "commands": [
                "vspacecode.space"
            ]
        },
        {
            "before": [
                ","
            ],
            "commands": [
                "vspacecode.space",
                {
                    "args": "m",
                    "command": "whichkey.triggerKey"
                }
            ]
        }
    ],
    "vim.visualstar": true,
    "vspacecode.bindingOverrides": [
        {
            "command": "terminal.focus",
            "icon": "terminal-view-icon",
            "keys": ";",
            "name": "Open Terminal",
            "type": "command"
        },
        {
            "keys": "t",
            "position": -1
        },
        {
            "bindings": [
                {
                    "command": "workbench.action.toggleSidebarVisibility",
                    "icon": "split-horizontal",
                    "key": "b",
                    "name": "Toggle side bar visibility",
                    "type": "command"
                },
                {
                    "command": "workbench.action.togglePanel",
                    "icon": "output",
                    "key": "j",
                    "name": "Toggle panel visibility",
                    "type": "command"
                },
                {
                    "command": "workbench.action.toggleMaximizedPanel",
                    "icon": "chevron-up",
                    "key": "m",
                    "name": "Toggle maximized panel",
                    "type": "command"
                },
                {
                    "command": "workbench.action.toggleActivityBarVisibility",
                    "icon": "tools",
                    "key": "t",
                    "name": "Toggle tool/activity bar visibility",
                    "type": "command"
                },
                {
                    "command": "workbench.action.toggleSidebarVisibility",
                    "icon": "layout-sidebar-left",
                    "key": "h",
                    "name": "Toggle Primary Side Bar",
                    "type": "command"
                },
                {
                    "command": "workbench.action.toggleAuxiliaryBar",
                    "icon": "layout-sidebar-right",
                    "key": "l",
                    "name": "Toggle Secondary Side Bar",
                    "type": "command"
                },
                {
                    "command": "workbench.action.toggleStatusbarVisibility",
                    "icon": "layout-statusbar",
                    "key": "a",
                    "name": "Toggle Status Bar",
                    "type": "command"
                }
            ],
            "icon": "tools",
            "keys": "t",
            "name": "+UI toggles",
            "type": "bindings"
        },
        {
            "keys": "S",
            "position": -1
        },
        {
            "keys": "s",
            "position": -1
        },
        {
            "bindings": [
                {
                    "command": "workbench.action.chat.newEditSession",
                    "icon": "debug-console",
                    "key": "d",
                    "name": "New edit session",
                    "type": "command"
                },
                {
                    "command": "workbench.view.explorer",
                    "icon": "list-tree",
                    "key": "e",
                    "name": "Show explorer",
                    "type": "command"
                },
                {
                    "command": "workbench.view.scm",
                    "icon": "source-control",
                    "key": "g",
                    "name": "Show source control",
                    "type": "command"
                },
                {
                    "command": "notifications.toggleList",
                    "icon": "comment",
                    "key": "n",
                    "name": "Show notification",
                    "type": "command"
                },
                {
                    "command": "chatgpt.sidebarSecondaryView.focus",
                    "icon": "notebook-open-as-text",
                    "key": "o",
                    "name": "Show codex view",
                    "type": "command"
                },
                {
                    "command": "workbench.actions.view.problems",
                    "icon": "error",
                    "key": "p",
                    "name": "Show problem",
                    "type": "command"
                },
                {
                    "command": "workbench.view.remote",
                    "icon": "remote-explorer",
                    "key": "r",
                    "name": "Show remote explorer",
                    "type": "command"
                },
                {
                    "command": "workbench.view.search",
                    "icon": "search",
                    "key": "s",
                    "name": "Show search",
                    "type": "command"
                },
                {
                    "command": "workbench.view.extension.test",
                    "icon": "beaker",
                    "key": "t",
                    "name": "Show test",
                    "type": "command"
                },
                {
                    "command": "workbench.view.extensions",
                    "icon": "extensions",
                    "key": "x",
                    "name": "Show extensions",
                    "type": "command"
                },
                {
                    "command": "outline.focus",
                    "icon": "outline-view-icon",
                    "key": "o",
                    "name": "show outline",
                    "type": "command"
                },
                {
                    "command": "workbench.view.debug",
                    "icon": "breakpoints-view-icon",
                    "key": "D",
                    "name": "show debug Explorer",
                    "type": "command"
                },
                {
                    "command": "gitlens.showSearchAndCompareView",
                    "icon": "notebook-open-as-text",
                    "key": "l",
                    "name": "show Gitlense",
                    "type": "command"
                },
                {
                    "command": "workbench.view.testing.focus",
                    "icon": "test-view-icon",
                    "key": "t",
                    "name": "Show tests",
                    "type": "command"
                },
                {
                    "command": "dockerContainers.focus",
                    "icon": "server",
                    "key": "k",
                    "name": "Show docker",
                    "type": "command"
                },
                {
                    "command": "workbench.panel.chat.view.copilot.focus",
                    "icon": "comment-discussion",
                    "key": "c",
                    "name": "Show chat",
                    "type": "command"
                }
            ],
            "keys": "s",
            "name": "+Show",
            "type": "bindings"
        },
        {
            "command": "testing.debugAtCursor",
            "icon": "debug-alt-small",
            "keys": "d.t",
            "name": "Run test at cursor",
            "type": "command"
        },
        {
            "command": "workbench.debug.action.focusCallStackView",
            "keys": "d.a",
            "name": "Call Stack",
            "type": "command"
        },
        {
            "command": "jupyter.runAndDebugCell",
            "icon": "notebook",
            "keys": "d.e",
            "name": "Run and Debug Jupyter Cell",
            "type": "command"
        },
        {
            "command": "workbench.action.debug.selectandstart",
            "icon": "debug",
            "keys": "d.D",
            "name": "Select and start debugging",
            "type": "command"
        },
        {
            "keys": "g",
            "position": -1
        },
        {
            "bindings": [
                {
                    "bindings": [
                        {
                            "command": "gitlens.views.unstageDirectory",
                            "key": "a",
                            "name": "Stage all files",
                            "type": "command"
                        },
                        {
                            "command": "git.unstageSelectedRanges",
                            "key": "s",
                            "name": "Stage selected range",
                            "type": "command"
                        },
                        {
                            "command": "git.unstage",
                            "key": "f",
                            "name": "Stage change in file",
                            "type": "command"
                        }
                    ],
                    "key": "u",
                    "name": "Unstage...",
                    "type": "bindings"
                },
                {
                    "bindings": [
                        {
                            "command": "git.stageAll",
                            "key": "a",
                            "name": "Stage all files",
                            "type": "command"
                        },
                        {
                            "command": "git.stageSelectedRanges",
                            "key": "s",
                            "name": "Stage selected range",
                            "type": "command"
                        },
                        {
                            "command": "git.stage",
                            "key": "f",
                            "name": "Stage change in file",
                            "type": "command"
                        }
                    ],
                    "key": "s",
                    "name": "Stage...",
                    "type": "bindings"
                },
                {
                    "bindings": [
                        {
                            "command": "git.revertSelectedRanges",
                            "key": "s",
                            "name": "Stage selected range",
                            "type": "command"
                        },
                        {
                            "command": "git.clean",
                            "key": "f",
                            "name": "Stage change in file",
                            "type": "command"
                        }
                    ],
                    "key": "r",
                    "name": "Revert...",
                    "type": "bindings"
                },
                {
                    "command": "gitlens.diffWithPrevious",
                    "key": "d",
                    "name": "Compare with Previous Revision",
                    "type": "command"
                },
                {
                    "command": "gitlens.views.fileHistory.focus",
                    "key": "h",
                    "name": "File History",
                    "type": "command"
                },
                {
                    "command": "gitlens.showLineHistoryView",
                    "key": "l",
                    "name": "Line History",
                    "type": "command"
                },
                {
                    "command": "gitlens.showSearchAndCompareView",
                    "key": "p",
                    "name": "Search and Compare",
                    "type": "command"
                },
                {
                    "command": "gitlens.showCommitsView",
                    "key": "o",
                    "name": "Show Commits",
                    "type": "command"
                },
                {
                    "command": "gitlens.showBranchesView",
                    "key": "b",
                    "name": "Show Branches",
                    "type": "command"
                },
                {
                    "command": "gitlens.toggleFileBlame",
                    "key": "a",
                    "name": "Blame",
                    "type": "command"
                }
            ],
            "keys": "g",
            "name": "Git...",
            "type": "bindings"
        }
    ],
    "whichkey.delay": 500,
    "window.autoDetectColorScheme": true,
    "window.commandCenter": false,
    "window.title": "${rootName}",
    "window.zoomLevel": 0.5,
    "workbench.activityBar.iconClickBehavior": "toggle",
    "workbench.activityBar.location": "hidden",
    "workbench.colorCustomizations": {
        "editor.lineHighlightBackground": "#DDB10030"
    },
    "workbench.commandPalette.experimental.askChatLocation": "quickChat",
    "workbench.commandPalette.experimental.enableNaturalLanguageSearch": true,
    "workbench.commandPalette.experimental.suggestCommands": true,
    "workbench.editor.highlightModifiedTabs": false,
    "workbench.editor.tabActionCloseVisibility": false,
    "workbench.iconTheme": null,
    "workbench.layoutControl.enabled": false,
    "workbench.panel.showLabels": false,
    "workbench.startupEditor": "none",
    "workbench.tree.indent": 14
}
